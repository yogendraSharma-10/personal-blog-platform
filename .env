# Server Configuration
# The port the Node.js server will listen on.
PORT=5000

# Node.js environment mode: development, production, or test.
NODE_ENV=development

# Database connection URL. Example for MongoDB.
# Replace with your actual database connection string.
DATABASE_URL="mongodb://localhost:27017/blog_platform_db"

# Secret key for JSON Web Token (JWT) authentication.
# IMPORTANT: Generate a strong, random key for production.
JWT_SECRET="supersecretjwtkeythatshouldbechangedinproduction123"

# Allowed origins for Cross-Origin Resource Sharing (CORS).
# In development, often set to the client's development URL.
# In production, specify your actual frontend domain(s).
CORS_ORIGIN="http://localhost:3000"

# --- Cross-Project Integrations ---
# URLs and API keys for other services in the interconnected system.
# These would be used by the server for backend-to-backend communication or data fetching.

# Real-time Weather Dashboard API
# Example: Used to fetch weather data for location-based blog posts or user profiles.
WEATHER_DASHBOARD_API_URL="http://localhost:5001/api/weather"
WEATHER_DASHBOARD_API_KEY="your_weather_dashboard_api_key"

# Custom URL Shortener API
# Example: Used to shorten URLs within blog posts or for sharing.
URL_SHORTENER_API_URL="http://localhost:5002/api/shorten"

# Interactive E-commerce Product Catalog API
# Example: If blog posts feature products, this API could fetch product details.
ECOMMERCE_CATALOG_API_URL="http://localhost:5003/api/products"

# AI-Powered Content Assistant API
# Example: Used for generating post ideas, proofreading, or summarizing content.
AI_ASSISTANT_API_URL="http://localhost:5004/api/ai/assist"
AI_ASSISTANT_API_KEY="your_ai_assistant_api_key"
AI_ASSISTANT_MODEL="gpt-3.5-turbo" # Example AI model

# --- Client Configuration (React App) ---
# Variables prefixed with REACT_APP_ are exposed to the client-side React application.
# These are typically used for the React app to know where to connect to its backend
# or to link to other frontend applications.

# The URL where the React client can reach the Node.js backend server.
REACT_APP_SERVER_URL="http://localhost:5000/api"

# Frontend URLs for other services, for direct linking from the blog platform UI.
REACT_APP_WEATHER_DASHBOARD_FRONTEND_URL="http://localhost:3001"
REACT_APP_URL_SHORTENER_FRONTEND_URL="http://localhost:3002"
REACT_APP_ECOMMERCE_CATALOG_FRONTEND_URL="http://localhost:3003"
REACT_APP_AI_ASSISTANT_FRONTEND_URL="http://localhost:3004"

# Example: Feature flag for AI integration in the UI
REACT_APP_ENABLE_AI_FEATURES="true"